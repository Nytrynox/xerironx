OPENROUTER_API_KEY=sk-or-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Canonical public site origin (no trailing slash). Used for Referer headers.
NEXT_PUBLIC_SITE_URL=https://xerironx.vercel.app

# Google OAuth for NextAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth secret and URL
NEXTAUTH_SECRET=changeme-in-dev
# In production set NEXTAUTH_URL to the deployed origin (must match Google Console):
# NEXTAUTH_URL=https://xerironx.vercel.app
# For local development uncomment the localhost value below:
# NEXTAUTH_URL=http://localhost:3000

# Firebase (client-side only; NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
